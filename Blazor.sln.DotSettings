	<s:String x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=E1DD2B04C1E27145AEFDE876317352B8/Text/@EntryValue">using System.Diagnostics.CodeAnalysis;
using Abstraction;
using Abstraction.Mediator;
using AspNetCore;
using AspNetCore.Mvc;
using AutoMapper;
using Domain;
using FluentValidation;
using GameServer2.Domain;
using MediatR;
using Microsoft.AspNetCore.Mvc;
using Resources;

namespace $namespace$;

[SuppressMessage("ReSharper", "UnusedType.Global")]
public static class $name$$END$
{
    internal class Validator : AbstractValidator&lt;Command&gt;
    {
        public Validator()
        {
            // TODO Validation
            // RuleFor(o =&gt; o.UserUid).GreaterThan(0u);
        }
    }

    public record Command : IRequest&lt;IResult&lt;Result&gt;&gt;;

    public record Result;

    internal class Handler(
        IDbContextFactory&lt;GameDbContext&gt; dbContextFactory,
        ResourceMap resourceMap,
        ILogger&lt;Handler&gt; logger)
        : IRequestHandler&lt;Command, IResult&lt;Result&gt;&gt;
    {
        public async Task&lt;IResult&lt;Result&gt;&gt; Handle(Command request, CancellationToken cancellationToken)
        {
            using var dbContext = dbContextFactory.CreateGameDb(DbProxy.Write);
            await dbContext.BeginTransactionAsync(cancellationToken);

            try
            {
                // TODO Business Logic

                await dbContext.SaveChangedAsync(cancellationToken);
                await dbContext.CommitAsync(cancellationToken);

                return IResult&lt;Result&gt;.Success(new Result(/* TODO Return Object */));
            }
            catch (ServerException e)
            {
                logger.LogError(e, $"{nameof($name$)} Error");
                await dbContext.RollbackAsync(cancellationToken);

                return IResult&lt;Result&gt;.Failed(e.ErrorCode);
            }
            catch (Exception e)
            {
                logger.LogError(e, "Unknown Error");
                await dbContext.RollbackAsync(cancellationToken);

                return IResult&lt;Result&gt;.Failed(ErrorCodes.Unknown);
            }
        }
    }
}

[ApiController]
[Route("api/[controller]")] // TODO RoutePath
public class $name$Endpoint : BaseEndpoint
{
    [HttpPost("$name$", Name = "$name$")] // TODO RoutePath
    [ProducesResponseType(typeof(Res), StatusCodes.Status200OK)]
    public async Task&lt;IActionResult&gt; $name$Async([FromBody] Req req)
    {
        var command = Mapper.Map&lt;$name$.Command&gt;(req);
        var result = await Mediator.Send(command);
        result.ThrowIfError();

        var response = Mapper.Map&lt;Res&gt;(result.Result);
        response.SetErrorCode(result);

        return Ok(response);
    }

    public record Req;

    public class Res : BaseRes
    {
    };

    [SuppressMessage("ReSharper", "UnusedType.Global")]
    internal class MapProfile : Profile
    {
        public MapProfile()
        {
            CreateMap&lt;Req, $name$.Command&gt;();

            CreateMap&lt;$name$.Result, Res&gt;();
        }
    }
}</s:String>
